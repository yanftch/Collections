<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>
    <style name="time_dialog" parent="android:style/Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="MyDialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="SlideUpDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>
    <!-- 基本属性 -->

    <style name="fw">
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="fwh" parent="@style/fw">
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="fwv" parent="@style/fw">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="fww" parent="@style/fw">
        <item name="android:layout_weight">1</item>
    </style>

    <style name="fwwv" parent="@style/fww">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="fwwh" parent="@style/fww">
        <item name="android:orientation">horizontal</item>
    </style>

</resources>
