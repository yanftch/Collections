<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:background="@color/color_f4f4f4"
              android:gravity="center_horizontal"
              android:orientation="vertical"
              android:padding="@dimen/dimen_20dp"
              tools:context="com.yanftch.collections.module.dialog_and_countdown.DialogAndCountdownBtnActivity">

    <com.iven.widget.countdownview.CountdownButton
        android:id="@+id/countdown_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@null"
        android:minWidth="@dimen/dimen_20dp"
        android:padding="@dimen/value_10_dp"
        android:text="获取验证码"
        android:textColor="@color/color_f80d0d"
        android:textSize="14sp"/>

    <Button
        android:id="@+id/btn_showdialog_01"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="显示Dialog"/>
    <Button
        android:id="@+id/btn_showdialog_02"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="一个Button的Dialog"/>
</LinearLayout>
