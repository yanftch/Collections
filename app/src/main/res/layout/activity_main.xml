<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              tools:context="com.yanftch.collections.MainActivity">

    <Button
        android:id="@+id/btn_01"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="btnTurnAct"
        android:text="侧滑ListView菜单"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btn_02"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="btnTurnAct"
        android:text="XRecyclerView"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btn_03"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="btnTurnAct"
        android:text="意见反馈选择图片5张"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btn_04"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="btnTurnAct"
        android:text="只能输入特定字符的EditText"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btn_05"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="btnTurnAct"
        android:text="圆形"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btn_06"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="btnTurnAct"
        android:text="ConvenientBanner"
        android:textAllCaps="false"/>


</LinearLayout>
