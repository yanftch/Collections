<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="time_dialog" parent="android:style/Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="MyDialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="SlideUpDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom</item>
    </style>
    <!-- 基本属性 -->
    <style name="ww">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="fw">
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="wf">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">fill_parent</item>
    </style>

    <style name="ff">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="fwh" parent="@style/fw">
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="wwh" parent="@style/ww">
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="fwv" parent="@style/fw">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="ffv" parent="@style/ff">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="wwv" parent="@style/ww">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="www" parent="@style/ww">
        <item name="android:layout_weight">1</item>
    </style>

    <style name="fww" parent="@style/fw">
        <item name="android:layout_weight">1</item>
    </style>

    <style name="ffwv" parent="@style/ffw">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="fwwv" parent="@style/fww">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="fwwh" parent="@style/fww">
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="ffwh" parent="@style/ffw">
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="ffw" parent="@style/ff">
        <item name="android:layout_weight">1</item>
    </style>

    <style name="vertical">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="wfw" parent="wf">
        <item name="android:layout_weight">1</item>
    </style>

    <style name="wfv" parent="@style/wf">
        <item name="android:orientation">vertical</item>
    </style>

    <style name="anim_menu_bottombar">
        <item name="android:windowEnterAnimation">@anim/menu_bottombar_in</item>
        <item name="android:windowExitAnimation">@anim/menu_bottombar_out</item>
    </style>

    <style name="CirclePopAnim" parent="@android:style/Animation.Activity">
        <item name="android:windowEnterAnimation">@anim/right_in</item>
        <item name="android:windowExitAnimation">@anim/right_out</item>
    </style>

    <!--背景透明的主题-->
    <style name="AppBaseTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!--
            Theme customizations available in newer API levels can go in
            res/values-vXX/app_styles.xml, while customizations related to
            backward-compatibility can go here.

        -->
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

</resources>
